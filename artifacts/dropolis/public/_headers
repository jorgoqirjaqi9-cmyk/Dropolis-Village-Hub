# Hashed Vite assets (JS/CSS bundles) — filename contains content hash, safe to cache forever
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Fonts — immutable (versioned via query string by Google Fonts or hash by Vite)
/*.woff2
  Cache-Control: public, max-age=31536000, immutable
/*.woff
  Cache-Control: public, max-age=31536000, immutable

# Static images — 1 day (content can be updated without filename change)
/*.jpg
  Cache-Control: public, max-age=86400
/*.jpeg
  Cache-Control: public, max-age=86400
/*.png
  Cache-Control: public, max-age=86400
/*.webp
  Cache-Control: public, max-age=86400
/*.svg
  Cache-Control: public, max-age=86400
/*.ico
  Cache-Control: public, max-age=86400

# PWA manifest & service worker — short cache so updates propagate quickly
/manifest.json
  Cache-Control: public, max-age=3600
/sw.js
  Cache-Control: no-cache, must-revalidate

# Sitemaps — 1 hour
/sitemap.xml
  Cache-Control: public, max-age=3600

# HTML pages (SPA shell + prerendered pages) — always revalidate
# This ensures article/village updates are picked up immediately
/
  Cache-Control: no-cache, must-revalidate
/*.html
  Cache-Control: no-cache, must-revalidate
